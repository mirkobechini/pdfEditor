# Backend Configuration — Development & Production Template
# Copy this file to `.env` and update values.
# IMPORTANT: `.env` is NOT committed to git (see .gitignore)
#
# Per sviluppo locale: lascia i default
# Per produzione (Render): imposta SECRET_KEY, DATABASE_URL, FRONTEND_URL, ecc.

# =====================
# APPLICATION
# =====================
APP_NAME=PdfEditor API
VERSION=0.1.0
DEBUG=True              # False in produzione

# =====================
# SECURITY — OBBLIGATORIE in produzione
# =====================
# Genera una chiave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
# Alternativa a SECRET_KEY (per Render/Docker)
JWT_SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =====================
# CORS — ORIGINI PERMESSE
# =====================
# Separare URL multipli con virgole. Es: http://localhost:3000,https://tueapp.onrender.com
ALLOWED_ORIGINS=http://localhost:3000

# =====================
# GOOGLE OAUTH (opzionale)
# =====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================
# DATABASE
# =====================
# Sviluppo: sqlite:///./pdf_editor.db
# Produzione (Render/PostgreSQL): postgresql://user:password@host:5432/pdfeditor
DATABASE_URL=sqlite:///./pdf_editor.db

# =====================
# STORAGE — FILE PDF
# =====================
# Storage locale (default)
UPLOAD_DIR=./storage/pdfs
MAX_UPLOAD_SIZE_MB=50
MAX_PAGE_COUNT=500
ALLOWED_EXTENSIONS=.pdf

# Storage S3 (Cloudflare R2 / AWS S3)
# Imposta STORAGE_BACKEND=s3 per abilitare storage cloud invece di locale
STORAGE_BACKEND=local             # "local" | "s3"
S3_BUCKET=
S3_ENDPOINT=                      # Es: https://<id>.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto                    # "auto" per R2, "us-east-1" per AWS

# =====================
# ADMIN
# =====================
# Super admin email (privilegi irrevocabili, promosso automaticamente all'avvio)
SUPER_ADMIN_EMAIL=mirkobechini@gmail.com

# =====================
# SMTP — EMAIL (reset password, notifiche)
# =====================
# Sviluppo: usa MailHog (localhost:1025, nessuna auth)
# Produzione: SendGrid (smtp.sendgrid.net:587)
# Oppure: smtp.gmail.com:587 con password app-specifica
SMTP_SERVER=localhost
SMTP_PORT=1025                    # 587 per SendGrid/Gmail TLS
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@pdfeditor.app

# =====================
# PASSWORD RESET
# =====================
RESET_TOKEN_EXPIRE_MINUTES=30

# =====================
# FRONTEND
# =====================
# URL del frontend (usato per link reset password)
FRONTEND_URL=http://localhost:3000

# =====================
# UNDO/REDO
# =====================
MAX_SNAPSHOTS=10

# =====================
# LICENSE ENFORCEMENT
# =====================
# True = tutte le feature disponibili a tutti (senza licenze)
# False = enforce tier-based restrictions (richiede sistema licenze attivo)
DISABLE_LICENSE_ENFORCEMENT=True
