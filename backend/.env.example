# Backend Configuration — Development Environment Template
# Copy this file to `.env` and update values for local development.
# IMPORTANT: `.env` is NOT committed to git (see .gitignore)

# Application
APP_NAME=PdfEditor API
VERSION=0.1.0
DEBUG=True

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google OAuth (leave empty if not using OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database
# SQLite (development): sqlite:///./pdf_editor.db
# PostgreSQL (production): postgresql://user:password@localhost:5432/pdfeditor
DATABASE_URL=sqlite:///./pdf_editor.db

# Storage
UPLOAD_DIR=./storage/pdfs
MAX_UPLOAD_SIZE_MB=50
MAX_PAGE_COUNT=500
ALLOWED_EXTENSIONS=.pdf

# Admin Configuration
# Super admin email (cannot be revoked) — will be promoted on first startup
# Default: admin@pdfeditor.local (if not set in .env)
SUPER_ADMIN_EMAIL=mirkobechini@gmail.com

# SMTP (for password reset emails)
# Use MailHog (localhost:1025) for development
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=False
SMTP_FROM_EMAIL=noreply@pdfeditor.app

# Password Reset
RESET_TOKEN_EXPIRE_MINUTES=30

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000
